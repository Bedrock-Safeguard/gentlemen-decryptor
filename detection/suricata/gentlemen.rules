# --- C2 and staging infrastructure (IP-based; update as infra rotates) -------

alert ip $HOME_NET any -> [91.107.247.163,45.86.230.112,149.28.137.179] any \
  (msg:"BEDROCK-SAFEGUARD Gentlemen — outbound to known ransomware C2 / staging infra"; \
   classtype:trojan-activity; sid:3300001; rev:1; \
   reference:url,github.com/Bedrock-Safeguard/gentlemen-decryptor;)

alert ip $HOME_NET any -> [176.120.22.0/24,193.143.1.0/24,91.212.166.0/24,45.134.26.0/24] any \
  (msg:"BEDROCK-SAFEGUARD Gentlemen — outbound to Proton66 operator subnet cluster"; \
   classtype:trojan-activity; sid:3300002; rev:1; \
   reference:url,github.com/Bedrock-Safeguard/gentlemen-decryptor;)

# --- SystemBC SOCKS5 signature (port 4001) ----------------------------------

alert tcp $HOME_NET any -> 45.86.230.112 4001 \
  (msg:"BEDROCK-SAFEGUARD Gentlemen — SystemBC SOCKS5 to known C2"; \
   flow:to_server,established; \
   classtype:trojan-activity; sid:3300003; rev:1;)

# --- Staging download from Packagec.ps1 ------------------------------------

alert http $HOME_NET any -> $EXTERNAL_NET any \
  (msg:"BEDROCK-SAFEGUARD Gentlemen — Packagec.ps1 staging download (Dvx.zip)"; \
   flow:established,to_server; http.method; content:"GET"; \
   http.uri; content:"/a/Dvx.zip"; nocase; \
   http.host; content:"149.28.137.179"; \
   classtype:trojan-activity; sid:3300004; rev:1;)

# --- TLS cert subject pivot (dev-1.secure.host) ----------------------------

alert tls $HOME_NET any -> $EXTERNAL_NET any \
  (msg:"BEDROCK-SAFEGUARD Gentlemen — TLS to Proton66 operator dev-1.secure.host cert"; \
   tls.cert_subject; content:"CN=dev-1.secure.host"; \
   classtype:trojan-activity; sid:3300005; rev:1;)

# --- TLS SNI for leak site -------------------------------------------------

alert tls $HOME_NET any -> $EXTERNAL_NET any \
  (msg:"BEDROCK-SAFEGUARD Gentlemen — Tor SNI leak site (tezwsse5…onion)"; \
   tls.sni; content:"tezwsse5czllksjb7cwp65rvnk4oobmzti2znn42i43bjdfd2prqqkad.onion"; nocase; \
   classtype:bad-unknown; sid:3300006; rev:1;)

